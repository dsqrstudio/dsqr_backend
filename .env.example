# Server Configuration
PORT=5000
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-required
JWT_EXPIRES_IN=7d
COOKIE_NAME=dsqr_token

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_TAX_ENABLED=true

# Frontend URLs (Update after frontend deployment)
FRONTEND_URL=https://your-frontend-domain.vercel.app
FRONTEND_ORIGIN=https://your-frontend-domain.vercel.app

# BunnyCDN Configuration
BUNNY_STORAGE_HOST=https://storage.bunnycdn.com
BUNNY_STORAGE_ZONE=dsqr-studio
BUNNY_STORAGE_API_KEY=your-bunnycdn-api-key-here
BUNNY_STORAGE_CDN_BASE=https://dsqrstudio.b-cdn.net
